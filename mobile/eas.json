{
  "cli": {
    "version": ">= 5.9.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "http://localhost:8000/api"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.bolibana.com/api",
        "SENTRY_ORG": "VOTRE_ORG_SENTRY",
        "SENTRY_PROJECT": "bolibana-sugu"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://www.bolibana.com/api",
        "SENTRY_ORG": "VOTRE_ORG_SENTRY",
        "SENTRY_PROJECT": "bolibana-sugu"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
